<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.petshare.bot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/user/Desktop/petshare_israel/venv/bin/python</string>
        <string>/Users/user/Desktop/petshare_israel/bot.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/user/Desktop/petshare_israel</string>

    <!-- Запускать сразу при загрузке этого LaunchAgent -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Перезапускать бота, если процесс упал -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Не перезапускать чаще, чем раз в 10 секунд (защита от цикла падений) -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Сырые stdout/stderr процесса — отдельно от bot.log с логами самого бота -->
    <key>StandardOutPath</key>
    <string>/Users/user/Desktop/petshare_israel/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/user/Desktop/petshare_israel/launchd.log</string>
</dict>
</plist>
